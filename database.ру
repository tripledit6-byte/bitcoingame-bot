def buy_car(user_id, car_id):
    car = CARS[car_id]
    user = get_user(user_id)
    if user[1] >= car["price"]:
        remove_coins(user_id, car["price"])
        cursor.execute("INSERT OR IGNORE INTO user_cars VALUES(?, ?)", (user_id, car_id))
        db.commit()
        return True
    return False

def equip_car(user_id, car_id):
    if car_id in get_user_cars(user_id):
        cursor.execute("UPDATE users SET current_car=? WHERE user_id=?", (car_id, user_id))
        db.commit()
        return True
    return False

