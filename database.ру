def get_mine_reward(level):
    if level <= 5: return random.randint(30, 80)
    elif level <= 10: return random.randint(60, 150)
    elif level <= 20: return random.randint(100, 250)
    elif level <= 30: return random.randint(200, 400)
    elif level <= 50: return random.randint(350, 600)
    else: return random.randint(500, 1000)

def get_xp_to_next_level(level, current_xp):
    return level * 100 - current_xp