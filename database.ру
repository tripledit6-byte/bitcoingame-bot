import sqlite3
import random
import time
from config import CARS, GARAGES, MINING_FARMS, HOUSES

db = sqlite3.connect("bitcoingame.db", check_same_thread=False)
cursor = db.cursor()

cursor.execute("""CREATE TABLE IF NOT EXISTS users(
    user_id INTEGER PRIMARY KEY, coins INTEGER, level INTEGER, xp INTEGER,
    wins INTEGER, loses INTEGER, last_bonus INTEGER, last_activity INTEGER,
    current_car TEXT, race_wins INTEGER, race_loses INTEGER, clan_name TEXT,
    current_garage TEXT, current_farm TEXT, current_house TEXT, last_farm_collect INTEGER)""")
db.commit()

cursor.execute("""CREATE TABLE IF NOT EXISTS user_cars(user_id INTEGER, car_id TEXT, PRIMARY KEY (user_id, car_id))""")
db.commit()
cursor.execute("""CREATE TABLE IF NOT EXISTS user_garages(user_id INTEGER, garage_id TEXT, PRIMARY KEY (user_id, garage_id))""")
db.commit()
cursor.execute("""CREATE TABLE IF NOT EXISTS user_farms(user_id INTEGER, farm_id TEXT, PRIMARY KEY (user_id, farm_id))""")
db.commit()
cursor.execute("""CREATE TABLE IF NOT EXISTS user_houses(user_id INTEGER, house_id TEXT, PRIMARY KEY (user_id, house_id))""")
db.commit()

def create_user(user_id):
    cursor.execute("SELECT * FROM users WHERE user_id=?", (user_id,))
    if not cursor.fetchone():
        cursor.execute("INSERT INTO users VALUES(?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)",
            (user_id, 50000, 1, 0, 0, 0, 0, int(time.time()), "lada", 0, 0, None, "garage_1", "farm_1", "house_1", 0))
        cursor.execute("INSERT INTO user_cars VALUES(?,?)", (user_id, "lada"))
        cursor.execute("INSERT INTO user_garages VALUES(?,?)", (user_id, "garage_1"))
        cursor.execute("INSERT INTO user_farms VALUES(?,?)", (user_id, "farm_1"))
        cursor.execute("INSERT INTO user_houses VALUES(?,?)", (user_id, "house_1"))
        db.commit()

def get_user(user_id):
    cursor.execute("SELECT * FROM users WHERE user_id=?", (user_id,))
    return cursor.fetchone()

def update_activity(user_id):
    cursor.execute("UPDATE users SET last_activity=? WHERE user_id=?", (int(time.time()), user_id))
    db.commit()

def add_coins(user_id, amount):
    cursor.execute("UPDATE users SET coins = coins + ? WHERE user_id=?", (amount, user_id))
    db.commit()
    update_activity(user_id)

def remove_coins(user_id, amount):
    cursor.execute("UPDATE users SET coins = coins - ? WHERE user_id=?", (amount, user_id))
    db.commit()
    update_activity(user_id)

def add_xp(user_id, amount):
    user = get_user(user_id)
    xp = user[3] + amount
    level = user[2]
    new_level = level
    if xp >= level * 100:
        xp = xp - (level * 100)
        new_level = level + 1
        add_coins(user_id, 500 * new_level)
    cursor.execute("UPDATE users SET xp=?, level=? WHERE user_id=?", (xp, new_level, user_id))
    db.commit()
    return new_level > level

def get_user_cars(user_id):
    cursor.execute("SELECT car_id FROM user_cars WHERE user_id=?", (user_id,))
    return [row[0] for row in cursor.fetchall()]

