async def handle_message(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user_id = update.effective_user.id
    text = update.message.text
    
    if context.user_data.get('waiting_for_casino_bet'):
        try:
            bet_amount = int(text)
            if bet_amount < 50:
                await update.message.reply_text("❌ Минимальная ставка: 50 BTC!", reply_markup=menu())
                context.user_data.pop('waiting_for_casino_bet', None)
                return
            
            user = get_user(user_id)
            if user[1] < bet_amount:
                await update.message.reply_text(f"❌ Недостаточно BTC! У тебя: {user[1]} BTC", reply_markup=menu())
                context.user_data.pop('waiting_for_casino_bet', None)
                return
            
            remove_coins(user_id, bet_amount)
            win, result = casino_bet(bet_amount)
            
            if win:
                add_coins(user_id, result)
                add_xp(user_id, 10)
                text_msg = f"🎉 ПОБЕДА! 🎉\n\n"
                text_msg += f"💰 Ставка: {bet_amount} BTC\n"
                text_msg += f"💵 Выигрыш: {result} BTC\n"
                text_msg += f"📈 Чистый выигрыш: +{result - bet_amount} BTC\n"
                text_msg += f"⭐ +10 XP"
            else:
                text_msg = f"💀 ПРОИГРЫШ! 💀\n\n"
                text_msg += f"💰 Ставка: {bet_amount} BTC\n"
                text_msg += f"💸 Потеряно: {bet_amount} BTC"
            
            user = get_user(user_id)
            text_msg += f"\n\n💰 Твой баланс: {user[1]} BTC"
            await update.message.reply_text(text_msg, reply_markup=menu())
            
        except ValueError:
            await update.message.reply_text("❌ Введи число!", reply_markup=menu())
        
        context.user_data.pop('waiting_for_casino_bet', None)

