async def send_command(update: Update, context: ContextTypes.DEFAULT_TYPE):
    sender_id = update.effective_user.id
    try:
        args = context.args
        if len(args) != 2:
            await update.message.reply_text("❌ Используй: /send ID сумма\nПример: /send 123456789 1000")
            return
        receiver_id = int(args[0])
        amount = int(args[1])
        if amount < 100:
            await update.message.reply_text("❌ Минимальная сумма: 100 BTC")
            return
        if sender_id == receiver_id:
            await update.message.reply_text("❌ Нельзя себе!")
            return
        sender = get_user(sender_id)
        if sender[1] < amount:
            await update.message.reply_text(f"❌ Не хватает! У тебя: {sender[1]} BTC")
            return
        receiver = get_user(receiver_id)
        if not receiver:
            await update.message.reply_text("❌ Пользователь не найден")
            return
        remove_coins(sender_id, amount)
        add_coins(receiver_id, amount)
        await update.message.reply_text(f"✅ Переведено {amount} BTC пользователю ID {receiver_id}")
    except:
        await update.message.reply_text("❌ Ошибка! Пример: /send 123456789 1000")

