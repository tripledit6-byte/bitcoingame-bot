def casino_bet(bet_amount):
    win_chance = 45
    win = random.randint(1, 100) <= win_chance
    if win:
        multiplier = random.uniform(1.5, 3.0)
        win_amount = int(bet_amount * multiplier)
        return True, win_amount
    else:
        return False, bet_amount

