    elif query.data.startswith("buy_farm_"):
        farm_id = query.data.replace("buy_farm_", "")
        await buy_farm_handler(update, context, user_id, farm_id)
    
    elif query.data.startswith("equip_farm_"):
        farm_id = query.data.replace("equip_farm_", "")
        await equip_farm_handler(update, context, user_id, farm_id)
    
    # ДОМ
    elif query.data == "house_menu":
        await houses_menu(update, context, user_id, True)
    
    elif query.data.startswith("buy_house_"):
        house_id = query.data.replace("buy_house_", "")
        await buy_house_handler(update, context, user_id, house_id)
    
    elif query.data.startswith("equip_house_"):
        house_id = query.data.replace("equip_house_", "")
        await equip_house_handler(update, context, user_id, house_id)
    
    elif query.data == "back":
        await query.edit_message_text("💰 Главное меню", reply_markup=menu())

